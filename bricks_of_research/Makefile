CC = cc
CFLAGS = -Werror -Wall -Wextra
.phony : all compile test test_pipe

all: decoration compile test fclean

compile: ft_pipe
test: test_pipe
ft_pipe: ft_pipe.c
	$(CC) $(CFLAGS) ft_pipe.c -o ft_pipe

test_pipe:
	./ft_pipe

fclean:
	rm ft_pipe

